  "keyFeatures": [
    "Fast repository history rewriting (orders of magnitude faster than filter-branch)",
    "Path-based filtering (keep or remove specific paths)",
    "File and directory renaming",
    "Commit message rewriting with hash updates",
    "Repository analysis mode to identify large files and paths",
    "Tag renaming and filtering",
    "Python library API for custom filtering scripts",
    "Automatic cleanup and repository optimization"
  ],
